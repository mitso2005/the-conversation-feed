<div class="max-w-xl mx-auto py-8">
  <div class="max-h-[600px] overflow-y-auto space-y-8">
    <% @articles.each do |article| %>
      <div class="flex flex-col items-center bg-white rounded-lg shadow p-6 hover:shadow-lg transition-shadow duration-200 border border-gray-200">
        
        <!-- Title -->
        <a href="<%= article[:url] %>" target="_blank" rel="noopener" class="mb-4 text-center">
          <h2 class="text-lg font-bold text-gray-800 hover:text-blue-600 transition-colors duration-150">
            <%= article[:title] %>
          </h2>
        </a>

        <!-- Image -->
        <% if article[:thumbnail] %>
          <a href="<%= article[:url] %>" target="_blank" rel="noopener" class="flex justify-center">
            <img src="<%= article[:thumbnail] %>" alt="Thumbnail"
              class="w-48 h-48 object-cover rounded-md border border-gray-200 hover:scale-105 transition-transform duration-200" />
          </a>
        <% else %>
          <div class="w-48 h-48 flex items-center justify-center bg-gray-100 rounded-md border border-gray-200 text-gray-400">
            No Image
          </div>
        <% end %>

      </div>
    <% end %>
  </div>
</div>
